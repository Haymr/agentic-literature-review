    {
      "parameters": {
        "jsCode": "const pdfItem = $input.all()[0];\nconst draftItem = $input.all()[1];\n\nconst combinedPdfText = pdfItem ? pdfItem.json.combined_pdf_text || '' : '';\nconst paperCount = pdfItem ? pdfItem.json.paper_count || 0 : 0;\nconst draftStr = draftItem ? draftItem.json.data || draftItem.json.text || '' : '';\n\nreturn [{\n  json: {\n    review_draft: draftStr,\n    source_papers_text: combinedPdfText,\n    paper_count: paperCount,\n    estimated_claims: 20\n  }\n}];"
      },
      "id": "576af853-ac38-46bf-955e-7b8fb57f67ba",
      "name": "Prepare Check Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -784,
        192
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Verify ALL factual claims in the following literature review draft against the SOURCE PAPERS provided below.\n\n=== LITERATURE REVIEW DRAFT (to be verified) ===\n{{ $json.review_draft }}\n=== END DRAFT ===\n\n=== SOURCE PAPERS (ground truth) ===\n{{ $json.source_papers_text }}\n=== END SOURCE PAPERS ===\n\nTotal papers available: {{ $json.paper_count }}\nEstimated claims to check: {{ $json.estimated_claims }}\n\nCarefully cross-reference every claim in the draft against the source papers above. Return ONLY a valid JSON verification report with no markdown fences."
      },
      "id": "0ba6a63d-a16f-476e-9c97-329b1d5b72f1",
      "name": "Checker LLM",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        -560,
        192
      ],
      "retryOnFail": true,
      "waitBetweenTries": 5000
    },
