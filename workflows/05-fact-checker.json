    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst papers = data.extracted_papers || (Array.isArray(data) ? data : [data]);\n\nconst formattedText = papers.map(p => {\n  const pid = p.paper_id || 'P?';\n  return `=== PAPER: ${pid} ===\\n` + JSON.stringify(p, null, 2);\n}).join('\\n\\n');\n\nreturn [{ json: { combined_pdf_text: formattedText, paper_count: papers.length } }];"
      },
      "id": "4be7dae6-855d-46d0-8878-e1a0ab4fe95f",
